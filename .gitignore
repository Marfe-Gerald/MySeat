# ===========================
# MySeat — .gitignore
# ===========================

# ----- Dependencies -----
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
vendor/

# ----- Build Output -----
dist/
build/
out/
.next/
.nuxt/
.vite/
.cache/
*.tsbuildinfo

# ----- Environment & Secrets -----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.pem
*.key
*.cert
secrets.json
config/secrets.*

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----- OS Files -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
ehthumbs.db

# ----- IDE & Editor -----
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~
.project
.classpath
.settings/

# ----- Testing & Coverage -----
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
.vitest/

# ----- Temporary Files -----
tmp/
temp/
*.tmp
*.bak
*.orig

# ----- Package Manager Locks (keep only one) -----
# Uncomment the lock file your project does NOT use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ----- Misc -----
.vercel
.netlify
.turbo
.parcel-cache
storybook-static/